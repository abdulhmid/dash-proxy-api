{
  "buildCommand": "go build -o api/index api/index.go",
  "devCommand": "go run cmd/api/main.go",
  "installCommand": "go mod download",
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go@1.0.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}